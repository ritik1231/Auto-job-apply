# Application
APP_ENV=development                        # development | staging | production
APP_VERSION=1.0.0
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR | CRITICAL
SECRET_KEY=change-me-in-production-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aijobapply
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aijobapply_test

# Google OAuth 2.0
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT (RS256)
# Local dev — generate PEM files:
#   mkdir secrets
#   openssl genrsa -out secrets/private.pem 2048
#   openssl rsa -in secrets/private.pem -pubout -out secrets/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_PRIVATE_KEY_PATH=./secrets/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/public.pem

# Production (Render) — base64-encoded PEM strings (overrides file paths above):
#   JWT_PRIVATE_KEY=$(base64 secrets/private.pem | tr -d '\n')
#   JWT_PUBLIC_KEY=$(base64 secrets/public.pem | tr -d '\n')
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Gmail token encryption (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# AI Provider (Gemini)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
AI_MAX_RESUME_TOKENS=4000
AI_MAX_JOB_POST_TOKENS=2000

# Gmail API
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send

# File Storage
RESUME_STORAGE_PATH=./storage/resumes
RESUME_MAX_SIZE_MB=5

# CORS — space-separated list of allowed origins
CORS_ALLOWED_ORIGINS=chrome-extension://your-extension-id

# Rate Limiting
RATE_LIMIT_JOB_EXTRACT=20/minute
RATE_LIMIT_APPLICATION=10/minute
RATE_LIMIT_RESUME_UPLOAD=5/hour
